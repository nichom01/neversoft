FROM maven:3.9-eclipse-temurin-21 AS build
WORKDIR /code
COPY lib-consumer-map/pom.xml lib-consumer-map/pom.xml
COPY lib-consumer-map/src/ lib-consumer-map/src/
RUN mvn -f lib-consumer-map/pom.xml install -DskipTests -B -q
COPY svc-risk/pom.xml svc-risk/pom.xml
RUN mvn -f svc-risk/pom.xml dependency:go-offline -B -q
COPY svc-risk/src/ svc-risk/src/
RUN mvn -f svc-risk/pom.xml package -DskipTests -B -q

FROM eclipse-temurin:21-jre
WORKDIR /work
COPY --from=build /code/svc-risk/target/quarkus-app /work/quarkus-app
EXPOSE 8082
USER 1001
CMD ["java", "-jar", "/work/quarkus-app/quarkus-run.jar", "-Dquarkus.http.host=0.0.0.0"]
