# JVM-mode image for validate-svc.
# Used instead of Dockerfile (native) because the plain drools-compiler/drools-mvel
# stack compiles DRL at runtime, which is incompatible with GraalVM native image.
# To enable native mode, migrate to the drools-quarkus extension
# (io.quarkus:quarkus-drools) which pre-compiles rules to an executable model.
FROM maven:3.9-eclipse-temurin-21 AS build
WORKDIR /code
COPY lib-consumer-map/pom.xml lib-consumer-map/pom.xml
COPY lib-consumer-map/src/ lib-consumer-map/src/
RUN mvn -f lib-consumer-map/pom.xml install -DskipTests -B -q
COPY svc-validate/pom.xml svc-validate/pom.xml
RUN mvn -f svc-validate/pom.xml dependency:go-offline -B -q
COPY svc-validate/src/ svc-validate/src/
RUN mvn -f svc-validate/pom.xml package -DskipTests -B -q

FROM eclipse-temurin:21-jre
WORKDIR /work
COPY --from=build /code/svc-validate/target/quarkus-app /work/quarkus-app
EXPOSE 8081
USER 1001
CMD ["java", "-jar", "/work/quarkus-app/quarkus-run.jar", "-Dquarkus.http.host=0.0.0.0"]
